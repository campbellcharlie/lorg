# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories
# vendor/
pb_data/
lorg_db/
builds*/
build/
bin/

# Wails uses cmd/lorg-app/build/ for both source assets (appicon.png,
# Info.plist template) and build output (build/bin/lorg.app). Keep
# the source assets tracked; the build/bin/ output is already
# excluded by the generic 'build/' rule above.
!cmd/lorg-app/build/
cmd/lorg-app/build/bin/

# Node.js dependencies
node_modules/
**/node_modules/
*/electron/dist/

# macOS system files
.DS_Store
**/.DS_Store

# Runtime data (built binary and database)
*.db
*.db-shm
*.db-wal
/lorg-bin
/lorg
lorg-bin
lorg-*-linux
lorg-*-darwin
lorg-*-windows
lorg-test-bin
/lorg-data/

# Profiling artifacts
*.profraw
*.prof

# TLS certs and keys (proxy-generated and user-provided)
*.pem
*.key
*.crt

# Build artifacts
*.md5

# Screenshots / demo assets
screenshots/

# Pentest engagement data
Projects/
KNOWN_ISSUES.md
ARCHITECTURE.md
docs/lorg-pentester-guide.md

# Local dev config
.mcp.json

# Runtime audit logs
audit/

# Local MCP test infrastructure — test server, test plan, results
.test-server/

# Wails CLI generates this when invoked without an existing frontend
cmd/lorg-app/frontend/wailsjs/

# Code-signing material — defense-in-depth so private keys, certs,
# CSRs, and notarization profiles can never be committed by accident.
# Real signing artifacts live OUTSIDE the repo at ~/.lorg-signing/.
*.key
*.p12
*.pfx
*.cer
*.crt
*.csr
*.pem
.lorg-signing/

# App-specific passwords / API keys / Apple Connect tokens.
*.appspecific
AuthKey_*.p8
notary*.json

# The lorg CA cert lives in ~/.config/lorg/ and is auto-generated;
# don't track if anyone moves it into the repo
ca.key
ca.crt

# Stale backups of swapped-out binaries
*.old

# Release artifacts (built locally for `make release` then uploaded
# to GitHub via `make publish` — no need to track them).
dist/
